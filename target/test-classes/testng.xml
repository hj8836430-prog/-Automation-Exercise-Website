<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="AutomationExercise Test Suite" parallel="false">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="tests.LoginTest"/>
        </classes>
    </test>

    <test name="Register Tests">
        <classes>
            <class name="tests.RegisterTest"/>
        </classes>
    </test>

    <test name="Contact Tests">
        <classes>
            <class name="tests.ContactTest"/>
        </classes>
    </test>

    <test name="Place Order Tests">
        <classes>
            <class name="tests.PlaceOrderLoginCheckoutTest"/>
            <class name="tests.PlaceOrderRegisterCheckoutTest"/>
        </classes>
    </test>

    <test name="Cart Tests">
        <classes>
            <class name="tests.RemoveProductsFromCartTest"/>
        </classes>
    </test>

    <test name="Products Tests">
        <classes>
            <class name="tests.ProductsTest">
                <methods>
                    <include name="testNavigateToProductsPage"/>
                    <include name="testSearchProduct"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>